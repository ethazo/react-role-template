# 复制为 .env 后按环境填写。
# VITE_API_BASE_URL 必填；VITE_API_PROXY_TARGET 开发期必填（dev server 代理目标，仅开发期使用）。
# VITE_APP_TITLE 选填（缺省回落默认值）。

# 站点标题：注入 index.html 的 <title>，每个项目改这一行即可。
VITE_APP_TITLE=域圆科技

# 后端请求基础路径（axios baseURL），开发与生产共用。
# - 开发期：务必填相对地址（如 /ulps），请求一律经 Vite dev server 代理到 VITE_API_PROXY_TARGET，规避 CORS。
# - 生产期：由网关/反向代理把该前缀转发到后端；或改填完整 URL（如 https://api.example.com/ulps）直连后端。
VITE_API_BASE_URL=/ulps

# 后端真实地址，仅开发期使用：Vite dev server 把 VITE_API_BASE_URL 前缀的请求代理到这里。
VITE_API_PROXY_TARGET=http://duomokuai.ulps.local.lzlzlzlz.xyz
