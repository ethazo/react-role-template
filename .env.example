# 复制为 .env 后按环境填写。以下变量均为必填。

# 后端请求基础路径（axios baseURL）。
# - 相对地址（如 /ulps）：开发期由 Vite 代理到 VITE_API_PROXY_TARGET；生产期由网关/反向代理转发。
# - 完整 URL（如 https://api.example.com/ulps）：直连后端，开发期不挂代理。
VITE_API_BASE_URL=/ulps

# 后端地址。当 VITE_API_BASE_URL 为相对地址时必填（开发期 Vite dev server 的代理目标）。
VITE_API_PROXY_TARGET=http://duomokuai.ulps.local.lzlzlzlz.xyz

